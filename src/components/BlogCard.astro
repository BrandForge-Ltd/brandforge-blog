---
import { urlFor } from '../lib/sanity';

interface Props {
  post: {
    _id: string;
    title: string;
    slug: { current: string };
    publishedAt: string;
    excerpt: string;
    coverImage: any;
    category?: { title: string };
    readingTime?: number;
  };
}

const { post } = Astro.props;
const formattedDate = new Date(post.publishedAt).toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric'
});
const readingTime = post.readingTime ? Math.max(1, post.readingTime) : 1;
---

<a href={`/blog/${post.slug.current}`} class="blog-card group">
  <div class="image-wrapper">
    {post.coverImage ? (
      <img 
        src={urlFor(post.coverImage).width(800).height(600).url()} 
        alt={post.title}
        class="cover-image"
      />
    ) : (
      <div class="image-placeholder"></div>
    )}
    {post.category && (
      <div class="category-badge">
        {post.category.title}
      </div>
    )}
  </div>
  
  <div class="content">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
      <p class="date" style="margin-bottom: 0;">{formattedDate}</p>
      <span style="font-size: 0.75rem; color: var(--gray); font-weight: 500;">{readingTime} min read</span>
    </div>
    <h3 class="title">{post.title}</h3>
    <p class="excerpt">{post.excerpt}</p>
    <div class="read-more">
      Read Article 
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </div>
  </div>
</a>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    background-color: var(--white);
    border-radius: 1rem;
    overflow: hidden;
    transition: transform 0.5s ease, box-shadow 0.5s ease;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    height: 100%;
  }

  .blog-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  }

  .image-wrapper {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background-color: var(--off-white);
  }

  .cover-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }

  .blog-card:hover .cover-image {
    transform: scale(1.05);
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom right, var(--gray-light), var(--off-white));
  }

  .category-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background-color: var(--zinc-800);
    color: var(--white);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem;
    border-radius: 9999px;
    z-index: 10;
  }

  .content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .date {
    color: var(--gray);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }

  .title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 1rem;
    color: var(--ink);
    transition: color 0.2s ease;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card:hover .title {
    color: var(--orange);
  }

  .excerpt {
    color: var(--charcoal);
    font-size: 0.875rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    opacity: 0.8;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .read-more {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--orange);
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: gap 0.2s ease;
  }

  .blog-card:hover .read-more {
    gap: 1rem;
  }
</style>
