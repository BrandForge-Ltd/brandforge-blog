---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="brand-section">
        <a href="https://brandforgeinc.com" class="logo-link">
          <img src="/brandforge-logo.png" alt="BrandForge Logo" style="height: 40px; margin-bottom: 1rem;" />
        </a>
        <p class="description">
          Insights, updates, and expert tips on design, technology, and branding.
        </p>
      </div>
      <div class="links-section">
        <div class="link-group">
          <h4>Explore</h4>
          <a href="/">Home</a>
          <a href="/blog">All Posts</a>
        </div>
        <div class="link-group">
          <h4>Company</h4>
          <a href="https://brandforgeinc.com">Main Website</a>
          <a href="https://brandforgeinc.com/contact">Contact Us</a>
        </div>
      </div>
    </div>
    
    <div class="bottom-bar">
      <div class="divider-dark"></div>
      <p>&copy; {currentYear} BrandForge. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--ink);
    color: var(--white);
    padding: calc(var(--section-py) * 0.8) 0 2rem;
    margin-top: auto;
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-bottom: 4rem;
  }

  @media (min-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr 1fr;
    }
  }

  .logo {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.5rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .accent {
    color: var(--orange);
  }

  .description {
    color: var(--gray-light);
    max-width: 300px;
    font-size: var(--text-small);
  }

  .links-section {
    display: flex;
    gap: 4rem;
  }

  .link-group h4 {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 1.5rem;
  }

  .link-group a {
    display: block;
    color: var(--white);
    margin-bottom: 0.8rem;
    font-size: var(--text-small);
    transition: color 0.2s ease;
  }

  .link-group a:hover {
    color: var(--orange);
  }

  .bottom-bar {
    padding-top: 2rem;
  }

  .divider-dark {
    width: 100%;
    height: 1px;
    background-color: var(--border-dark);
    margin-bottom: 2rem;
  }

  .bottom-bar p {
    color: var(--gray);
    font-size: var(--text-small);
    text-align: center;
  }
</style>
