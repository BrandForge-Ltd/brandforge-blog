---
import A11yControls from './A11yControls.astro';

export interface Props {
  tocHeadings: { id: string; text: string; level: number }[];
}

const { tocHeadings = [] } = Astro.props;
---

<div class="mobile-toc-wrapper">
  <!-- Floating Action Button -->
  <button id="mobileTocBtn" class="mobile-toc-fab" aria-label="Options & Navigation">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="8" y1="6" x2="21" y2="6"></line>
      <line x1="8" y1="12" x2="21" y2="12"></line>
      <line x1="8" y1="18" x2="21" y2="18"></line>
      <line x1="3" y1="6" x2="3.01" y2="6"></line>
      <line x1="3" y1="12" x2="3.01" y2="12"></line>
      <line x1="3" y1="18" x2="3.01" y2="18"></line>
    </svg>
  </button>

  <!-- Bottom Sheet (Always rendered to show A11yControls) -->
  <div id="mobileTocSheet" class="mobile-toc-sheet">
    <div class="sheet-header">
      <h3>Options & Navigation</h3>
      <button id="closeTocBtn" class="close-sheet-btn" aria-label="Close">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="sheet-content">
      <div style="margin-bottom: 2rem; display: flex; justify-content: center;">
        <A11yControls />
      </div>
      
      {tocHeadings.length > 0 && (
        <ul class="mobile-toc-list">
          {tocHeadings.map((heading: any) => (
            <li class={`mobile-toc-item level-${heading.level}`}>
              <a href={`#${heading.id}`} class="toc-link">{heading.text}</a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>

  <!-- Backdrop -->
  <div id="mobileTocBackdrop" class="mobile-toc-backdrop"></div>
</div>

<script>
  const tocBtn = document.getElementById('mobileTocBtn');
  const closeBtn = document.getElementById('closeTocBtn');
  const sheet = document.getElementById('mobileTocSheet');
  const backdrop = document.getElementById('mobileTocBackdrop');
  const tocLinks = document.querySelectorAll('.toc-link');

  const openSheet = () => {
    if (sheet && backdrop) {
      sheet.classList.add('open');
      backdrop.classList.add('open');
      document.body.style.overflow = 'hidden'; // Prevent background scrolling
    }
  };

  const closeSheet = () => {
    if (sheet && backdrop) {
      sheet.classList.remove('open');
      backdrop.classList.remove('open');
      document.body.style.overflow = '';
    }
  };

  if (tocBtn) tocBtn.addEventListener('click', openSheet);
  if (closeBtn) closeBtn.addEventListener('click', closeSheet);
  if (backdrop) backdrop.addEventListener('click', closeSheet);
  
  // Close sheet when a link is clicked
  tocLinks.forEach(link => {
    link.addEventListener('click', closeSheet);
  });
</script>

<style>
  .mobile-toc-wrapper {
    display: none;
  }

  /* Only show on mobile screens */
  @media (max-width: 1023px) {
    .mobile-toc-wrapper {
      display: block;
    }
  }

  /* Floating Action Button */
  .mobile-toc-fab {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background-color: var(--orange);
    color: var(--white);
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 15px rgba(255, 107, 0, 0.4);
    cursor: pointer;
    z-index: 90;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .mobile-toc-fab:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 20px rgba(255, 107, 0, 0.5);
  }

  /* Bottom Sheet */
  .mobile-toc-sheet {
    position: fixed;
    bottom: -100%;
    left: 0;
    width: 100%;
    max-height: 85vh;
    background-color: var(--white);
    border-radius: 1.5rem 1.5rem 0 0;
    z-index: 100;
    transition: bottom 0.3s cubic-bezier(0.175, 0.885, 0.32, 1);
    display: flex;
    flex-direction: column;
    box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.15);
  }

  .mobile-toc-sheet.open {
    bottom: 0;
  }

  .sheet-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .sheet-header h3 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--ink);
    margin: 0;
  }

  .close-sheet-btn {
    background: none;
    border: none;
    color: var(--gray);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    transition: color 0.2s ease;
  }

  .close-sheet-btn:hover {
    color: var(--ink);
  }

  .sheet-content {
    padding: 1.5rem;
    overflow-y: auto;
    flex: 1;
  }

  .mobile-toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .mobile-toc-item a {
    color: var(--charcoal);
    font-size: 1.125rem;
    text-decoration: none;
    transition: color 0.2s ease;
    display: block;
    line-height: 1.4;
  }

  .mobile-toc-item a:hover {
    color: var(--orange);
  }

  .mobile-toc-item.level-3 {
    padding-left: 1.5rem;
    font-size: 1rem;
    opacity: 0.9;
  }

  /* Backdrop */
  .mobile-toc-backdrop {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    z-index: 95;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .mobile-toc-backdrop.open {
    opacity: 1;
    pointer-events: auto;
  }
</style>
