---
import { client } from '../lib/sanity';
import { categoriesQuery } from '../lib/queries';

const categories = await client.fetch(categoriesQuery);
---
<header class="header">
  <div class="container">
    <nav class="nav">
      <a href="/" class="logo-link">
        <img src="/brandforge-logo.png" alt="BrandForge Logo" style="height: 32px;" />
        <span class="logo-text">BLOG</span>
      </a>
      
      <button class="mobile-menu-btn" aria-label="Toggle menu" aria-expanded="false">
        <span class="hamburger"></span>
      </button>

      <div class="nav-links">
        <a href="/" class="nav-link">Home</a>
        
        <div class="dropdown">
          <button class="nav-link dropdown-toggle">Categories <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg></button>
          <div class="dropdown-menu">
            {categories.map((cat: any) => (
              <a href={`/category/${cat.slug}`} class="dropdown-item">{cat.title}</a>
            ))}
          </div>
        </div>

        <a href="https://brandforgeinc.com/services" class="nav-link">Services</a>
        <a href="https://brandforgeinc.com" class="nav-link btn-link">Main Website</a>
      </div>
    </nav>
  </div>
</header>

<div class="mobile-overlay"></div>

<script>
  const mobileBtn = document.querySelector('.mobile-menu-btn');
  const navLinks = document.querySelector('.nav-links');
  const overlay = document.querySelector('.mobile-overlay');
  const dropdownToggles = document.querySelectorAll('.dropdown-toggle');

  const closeMenu = () => {
    mobileBtn?.setAttribute('aria-expanded', 'false');
    navLinks?.classList.remove('active');
    mobileBtn?.classList.remove('active');
    overlay?.classList.remove('active');
    document.body.style.overflow = '';
  };

  if (mobileBtn && navLinks && overlay) {
    mobileBtn.addEventListener('click', () => {
      const isExpanded = mobileBtn.getAttribute('aria-expanded') === 'true';
      if (isExpanded) {
        closeMenu();
      } else {
        mobileBtn.setAttribute('aria-expanded', 'true');
        navLinks.classList.add('active');
        mobileBtn.classList.add('active');
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden'; // Prevent scrolling
      }
    });

    overlay.addEventListener('click', closeMenu);
  }

  // Handle mobile dropdowns
  dropdownToggles.forEach(toggle => {
    toggle.addEventListener('click', (e) => {
      if (window.innerWidth <= 768) {
        e.preventDefault();
        const dropdown = toggle.closest('.dropdown');
        dropdown?.classList.toggle('mobile-active');
      }
    });
  });
</script>

<style>
  .header {
    background-color: var(--white);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 80px;
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    z-index: 102; /* Keep above overlay if needed */
  }

  .logo-text {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.25rem;
    color: var(--orange);
    letter-spacing: -0.02em;
    transform: translateY(2px);
  }

  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    z-index: 102; /* Above the off-canvas menu */
  }

  .hamburger {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--ink);
    position: relative;
    transition: background-color 0.2s ease;
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    width: 24px;
    height: 2px;
    background-color: var(--ink);
    left: 0;
    transition: transform 0.2s ease, top 0.2s ease;
  }

  .hamburger::before {
    top: -6px;
  }

  .hamburger::after {
    top: 6px;
  }

  .mobile-menu-btn.active .hamburger {
    background-color: transparent;
  }

  .mobile-menu-btn.active .hamburger::before {
    top: 0;
    transform: rotate(45deg);
  }

  .mobile-menu-btn.active .hamburger::after {
    top: 0;
    transform: rotate(-45deg);
  }

  .mobile-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    z-index: 100;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .nav-link {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--ink);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background: none;
    border: none;
    cursor: pointer;
    text-decoration: none;
  }

  .nav-link:hover {
    color: var(--orange);
  }

  .btn-link {
    background-color: var(--zinc-800);
    color: var(--white);
    padding: 0.5rem 1rem;
    border-radius: 9999px;
  }

  .btn-link:hover {
    background-color: var(--orange);
    color: var(--white);
  }

  /* Dropdown */
  .dropdown {
    position: relative;
  }

  .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 200px;
    background-color: var(--white);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: all 0.2s ease;
    padding: 0.5rem;
    display: flex;
    flex-direction: column;
  }

  .dropdown:hover .dropdown-menu,
  .dropdown.mobile-active .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-item {
    padding: 0.75rem 1rem;
    color: var(--charcoal);
    font-size: 0.875rem;
    border-radius: 0.25rem;
    transition: background-color 0.2s ease, color 0.2s ease;
    text-decoration: none;
  }

  .dropdown-item:hover {
    background-color: var(--off-white);
    color: var(--orange);
  }

  @media (max-width: 768px) {
    .mobile-menu-btn {
      display: block;
    }

    .mobile-overlay {
      display: block;
    }

    .mobile-overlay.active {
      opacity: 1;
      visibility: visible;
    }

    .nav-links {
      position: fixed;
      top: 0;
      right: 0;
      width: 85%;
      max-width: 400px;
      height: 100vh;
      background-color: var(--white);
      flex-direction: column;
      align-items: flex-start;
      padding: 100px 2rem 2rem 2rem;
      gap: 0;
      box-shadow: -10px 0 20px rgba(0,0,0,0.05);
      transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.77, 0, 0.175, 1);
      z-index: 101;
      overflow-y: auto;
    }

    .nav-links.active {
      transform: translateX(0);
    }

    .nav-link {
      width: 100%;
      padding: 1.25rem 0;
      font-size: 1.125rem;
      border-bottom: 1px solid var(--border);
    }

    .btn-link {
      margin-top: 2rem;
      width: 100%;
      text-align: center;
      padding: 1rem;
      border-radius: 0.5rem;
    }

    .dropdown {
      width: 100%;
    }

    .dropdown-menu {
      position: static;
      box-shadow: none;
      border: none;
      padding: 0;
      opacity: 0;
      visibility: hidden;
      height: 0;
      overflow: hidden;
      transform: none;
      transition: none;
      background-color: var(--off-white);
    }

    .dropdown.mobile-active .dropdown-menu {
      opacity: 1;
      visibility: visible;
      height: auto;
      padding: 0.5rem 0;
      border-bottom: 1px solid var(--border);
    }

    .dropdown-item {
      padding: 1rem 1.5rem;
      font-size: 1rem;
    }
  }
</style>
