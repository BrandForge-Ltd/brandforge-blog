---
import { client } from '../lib/sanity';
import { categoriesQuery, latestPostsQuery } from '../lib/queries';
import { urlFor } from '../lib/sanity';

const categories = await client.fetch(categoriesQuery);
const latestPosts = await client.fetch(latestPostsQuery);
---
<aside class="sidebar">
  <div class="sidebar-widget newsletter-widget">
    <h3>Subscribe to Our Newsletter</h3>
    <p>Get the latest insights delivered straight to your inbox.</p>
    <form class="newsletter-form" onsubmit="event.preventDefault(); alert('Subscribed!');">
      <input type="email" placeholder="Email Address" required />
      <button type="submit" class="btn-primary" style="min-height: 40px; padding: 0.5rem 1rem;">Subscribe</button>
    </form>
  </div>

  <div class="sidebar-widget categories-widget">
    <h3>Categories</h3>
    <ul class="categories-list">
      {categories.map((cat: any) => (
        <li>
          <a href={`/category/${cat.slug}`} class="category-link">
            {cat.title}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="sidebar-widget latest-posts-widget">
    <h3>Latest Posts</h3>
    <div class="latest-posts-list">
      {latestPosts.map((post: any) => {
        const formattedDate = new Date(post.publishedAt).toLocaleDateString('en-US', {
          month: 'short',
          day: 'numeric',
          year: 'numeric'
        });
        return (
          <a href={`/blog/${post.slug.current}`} class="latest-post-card">
            <div class="latest-post-img">
              {post.coverImage ? (
                <img src={urlFor(post.coverImage).width(150).height(150).url()} alt={post.title} />
              ) : (
                <div class="img-placeholder"></div>
              )}
            </div>
            <div class="latest-post-content">
              <h4>{post.title}</h4>
              <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 0.25rem;">
                <span>{formattedDate}</span>
                <span style="color: var(--orange); font-weight: 500;">{post.readingTime ? Math.max(1, post.readingTime) : 1} min read</span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</aside>

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: sticky;
    top: 100px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    padding-right: 0.5rem; /* prevent scrollbar from hitting content */
  }

  /* Custom scrollbar for sidebar */
  .sidebar::-webkit-scrollbar {
    width: 6px;
    background-color: transparent;
  }
  .sidebar::-webkit-scrollbar-thumb {
    background-color: transparent;
    border-radius: 4px;
  }
  .sidebar:hover::-webkit-scrollbar-thumb {
    background-color: var(--gray-light);
  }

  .sidebar-widget {
    background-color: var(--white);
    padding: 1.5rem;
    border-radius: 1rem;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
  }

  .sidebar-widget h3 {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    margin-bottom: 1rem;
    color: var(--ink);
    border-bottom: 2px solid var(--off-white);
    padding-bottom: 0.5rem;
  }

  /* Newsletter */
  .newsletter-widget p {
    font-size: var(--text-small);
    color: var(--gray);
    margin-bottom: 1rem;
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .newsletter-form input {
    padding: 0.75rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    font-family: var(--font-sans);
    font-size: var(--text-small);
    outline: none;
  }
  
  .newsletter-form input:focus {
    border-color: var(--orange);
  }

  /* Categories */
  .categories-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .category-link {
    display: block;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    color: var(--charcoal);
    font-weight: 500;
    font-size: 0.875rem;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .category-link:hover {
    background-color: var(--off-white);
    color: var(--orange);
  }

  /* Latest Posts */
  .latest-posts-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .latest-post-card {
    display: flex;
    gap: 1rem;
    align-items: center;
    transition: transform 0.2s ease;
  }

  .latest-post-card:hover {
    transform: translateX(4px);
  }

  .latest-post-card:hover h4 {
    color: var(--orange);
  }

  .latest-post-img {
    width: 60px;
    height: 60px;
    border-radius: 0.5rem;
    overflow: hidden;
    flex-shrink: 0;
  }

  .latest-post-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .img-placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--gray-light);
  }

  .latest-post-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .latest-post-content h4 {
    font-size: 0.875rem;
    color: var(--ink);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.2s ease;
  }

  .latest-post-content span {
    font-size: 0.6875rem;
    color: var(--gray);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
