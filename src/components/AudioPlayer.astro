---
export interface Props {
  textToRead: string;
}

const { textToRead } = Astro.props;
---

<div class="audio-player">
  <button id="playBtn" class="audio-btn" aria-label="Listen to article">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path></svg>
    <span>Listen to Article</span>
  </button>
  <button id="pauseBtn" class="audio-btn hidden" aria-label="Pause reading">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16"></rect><rect x="14" y="4" width="4" height="16"></rect></svg>
    <span>Pause</span>
  </button>
  <button id="stopBtn" class="audio-btn hidden" aria-label="Stop reading">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg>
  </button>
  
  <div class="audio-status hidden" id="audioStatus">
    <div class="playing-indicator">
      <span></span><span></span><span></span>
    </div>
    <span class="status-text">Playing...</span>
  </div>

  {/* Hidden text container for the script to read */}
  <div id="textToRead" style="display: none;">{textToRead}</div>
</div>

<script>
  const playBtn = document.getElementById('playBtn');
  const pauseBtn = document.getElementById('pauseBtn');
  const stopBtn = document.getElementById('stopBtn');
  const textContainer = document.getElementById('textToRead');
  const audioStatus = document.getElementById('audioStatus');
  const statusText = audioStatus?.querySelector('.status-text');

  if ('speechSynthesis' in window && playBtn && pauseBtn && stopBtn && textContainer && audioStatus && statusText) {
    const text = textContainer.textContent || '';
    let utterance = new SpeechSynthesisUtterance(text);
    
    // Set a good voice if available
    window.speechSynthesis.onvoiceschanged = () => {
      const voices = window.speechSynthesis.getVoices();
      const preferredVoice = voices.find(v => v.name.includes('Google') || v.name.includes('Samantha') || v.lang === 'en-US');
      if (preferredVoice) {
        utterance.voice = preferredVoice;
      }
    };

    utterance.onend = () => {
      resetUI();
    };

    utterance.onerror = () => {
      resetUI();
    };

    const updateUIState = (state: 'playing' | 'paused' | 'stopped') => {
      if (state === 'playing') {
        playBtn.classList.add('hidden');
        pauseBtn.classList.remove('hidden');
        stopBtn.classList.remove('hidden');
        audioStatus.classList.remove('hidden');
        statusText.textContent = 'Playing...';
        audioStatus.classList.remove('paused');
      } else if (state === 'paused') {
        playBtn.classList.remove('hidden');
        pauseBtn.classList.add('hidden');
        stopBtn.classList.remove('hidden');
        audioStatus.classList.remove('hidden');
        statusText.textContent = 'Paused';
        audioStatus.classList.add('paused');
      } else {
        resetUI();
      }
    };

    const resetUI = () => {
      playBtn.classList.remove('hidden');
      pauseBtn.classList.add('hidden');
      stopBtn.classList.add('hidden');
      audioStatus.classList.add('hidden');
      audioStatus.classList.remove('paused');
    };

    playBtn.addEventListener('click', () => {
      if (window.speechSynthesis.paused) {
        window.speechSynthesis.resume();
      } else {
        window.speechSynthesis.cancel(); // Cancel any ongoing speech
        // Re-create utterance in case it was modified
        utterance = new SpeechSynthesisUtterance(textContainer.textContent || '');
        const voices = window.speechSynthesis.getVoices();
        const preferredVoice = voices.find(v => v.name.includes('Google') || v.name.includes('Samantha') || v.lang === 'en-US');
        if (preferredVoice) {
          utterance.voice = preferredVoice;
        }
        
        utterance.onend = resetUI;
        utterance.onerror = resetUI;
        window.speechSynthesis.speak(utterance);
      }
      updateUIState('playing');
    });

    pauseBtn.addEventListener('click', () => {
      window.speechSynthesis.pause();
      updateUIState('paused');
    });

    stopBtn.addEventListener('click', () => {
      window.speechSynthesis.cancel();
      updateUIState('stopped');
    });

    // Cleanup on page hide
    window.addEventListener('pagehide', () => {
      window.speechSynthesis.cancel();
    });
  } else if (playBtn) {
    // Browser doesn't support Web Speech API
    playBtn.innerHTML = '<span>Audio not supported</span>';
    playBtn.disabled = true;
    playBtn.style.opacity = '0.5';
    playBtn.style.cursor = 'not-allowed';
  }
</script>

<style>
  .audio-player {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background-color: var(--off-white);
    border-radius: 9999px;
    border: 1px solid var(--border);
    margin: 1.5rem 0;
    width: fit-content;
  }

  .audio-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: none;
    border: none;
    color: var(--charcoal);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.875rem;
    cursor: pointer;
    padding: 0.25rem;
    transition: color 0.2s ease;
  }

  .audio-btn:hover {
    color: var(--orange);
  }

  .audio-btn.hidden {
    display: none;
  }

  .audio-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: 0.5rem;
    padding-left: 1rem;
    border-left: 1px solid var(--border);
  }

  .status-text {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--orange);
  }

  .playing-indicator {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 12px;
  }

  .playing-indicator span {
    display: block;
    width: 3px;
    background-color: var(--orange);
    border-radius: 2px;
    animation: pulse 1s infinite ease-in-out alternate;
  }

  .playing-indicator span:nth-child(1) { height: 40%; animation-delay: 0s; }
  .playing-indicator span:nth-child(2) { height: 100%; animation-delay: 0.2s; }
  .playing-indicator span:nth-child(3) { height: 60%; animation-delay: 0.4s; }

  .audio-status.paused .playing-indicator span {
    animation-play-state: paused;
    height: 20%;
  }

  @keyframes pulse {
    0% { transform: scaleY(0.5); }
    100% { transform: scaleY(1); }
  }
</style>
