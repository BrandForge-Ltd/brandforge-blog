---
// AudioPlayer Component
---
<div class="premium-audio-player" id="audioPlayerContainer">

  <!-- Row 1: Cover art + title + waveform -->
  <div class="player-top-row">
    <div class="player-cover">
      <div class="disc-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <circle cx="12" cy="12" r="3"></circle>
        </svg>
      </div>
    </div>

    <div class="player-info">
      <span class="player-label">LISTEN TO ARTICLE</span>
      <div class="waveform" id="waveform">
        <span class="bar"></span><span class="bar"></span><span class="bar"></span><span class="bar"></span>
        <span class="bar"></span><span class="bar"></span><span class="bar"></span><span class="bar"></span>
        <span class="bar"></span><span class="bar"></span><span class="bar"></span><span class="bar"></span>
        <span class="bar"></span><span class="bar"></span><span class="bar"></span><span class="bar"></span>
      </div>
    </div>

    <span class="status-badge" id="statusText">Ready</span>
  </div>

  <!-- Row 2: Controls + voice selector -->
  <div class="player-bottom-row">
    <div class="player-controls">
      <button id="playBtn" class="play-pause-btn" aria-label="Listen to article">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="6 3 20 12 6 21 6 3"></polygon></svg>
      </button>
      <button id="pauseBtn" class="play-pause-btn hidden" aria-label="Pause">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"></rect><rect x="14" y="4" width="4" height="16"></rect></svg>
      </button>
      <button id="stopBtn" class="stop-btn hidden" aria-label="Stop" title="Stop">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><rect x="4" y="4" width="16" height="16" rx="2"></rect></svg>
      </button>
    </div>

    <div class="voice-selector" id="voiceDropdownContainer">
      <button id="voiceDropdownBtn" class="voice-pill" aria-label="Change Voice">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" y1="19" x2="12" y2="22"></line></svg>
        <span id="selectedVoiceLabel">Asteria</span>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
      </button>
      <div id="voiceDropdownMenu" class="voice-menu hidden">
        <div class="menu-title">Select Voice</div>
        <div class="voice-grid">
          <button class="voice-chip active" data-voice="asteria">Asteria</button>
          <button class="voice-chip" data-voice="luna">Luna</button>
          <button class="voice-chip" data-voice="orion">Orion</button>
          <button class="voice-chip" data-voice="zeus">Zeus</button>
        </div>
      </div>
    </div>
  </div>

</div>

<script>
  const playBtn = document.getElementById('playBtn');
  const pauseBtn = document.getElementById('pauseBtn');
  const stopBtn = document.getElementById('stopBtn');
  const statusText = document.getElementById('statusText');
  const waveform = document.getElementById('waveform');
  const playerContainer = document.getElementById('audioPlayerContainer');

  // Voice dropdown
  const voiceDropdownBtn = document.getElementById('voiceDropdownBtn');
  const voiceDropdownMenu = document.getElementById('voiceDropdownMenu');
  const voiceChips = document.querySelectorAll('.voice-chip');
  const selectedVoiceLabel = document.getElementById('selectedVoiceLabel');

  let selectedVoice = 'asteria';

  if (voiceDropdownBtn && voiceDropdownMenu) {
    voiceDropdownBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      voiceDropdownMenu.classList.toggle('hidden');
    });
    document.addEventListener('click', () => voiceDropdownMenu.classList.add('hidden'));
    voiceDropdownMenu.addEventListener('click', (e) => e.stopPropagation());

    voiceChips.forEach(chip => {
      chip.addEventListener('click', () => {
        voiceChips.forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        selectedVoice = chip.getAttribute('data-voice') || 'asteria';
        if (selectedVoiceLabel) selectedVoiceLabel.textContent = chip.textContent || 'Asteria';
        voiceDropdownMenu.classList.add('hidden');
        if (currentAudio) { currentAudio.pause(); currentAudio = null; }
        updateUIState('ready');
        resetHighlight();
        currentElementIndex = 0;
      });
    });
  }

  let readableElements: Element[] = [];
  let currentElementIndex = 0;
  let currentAudio: HTMLAudioElement | null = null;
  let nextAudio: HTMLAudioElement | null = null;
  let isPlaying = false;
  let isPaused = false;

  const getReadableElements = () => {
    if (readableElements.length === 0) {
      readableElements = Array.from(
        document.querySelectorAll('.prose p, .prose h2, .prose h3, .prose li')
      ).filter(el => (el.textContent || '').trim().length > 0);
    }
    return readableElements;
  };

  const updateUIState = (state: string) => {
    if (!playBtn || !pauseBtn || !stopBtn || !statusText || !waveform || !playerContainer) return;
    const isActive = state === 'generating' || state === 'playing';

    playBtn.classList.toggle('hidden', state === 'generating' || state === 'playing');
    pauseBtn.classList.toggle('hidden', state !== 'playing');
    stopBtn.classList.toggle('hidden', !isActive && state !== 'paused');
    waveform.classList.toggle('active', isActive);
    playerContainer.classList.toggle('is-playing', isActive);

    const labels: Record<string, string> = {
      generating: 'Loading…',
      playing: 'Playing',
      paused: 'Paused',
      error: 'Error',
      ready: 'Ready',
    };
    statusText.textContent = labels[state] || 'Ready';
    if (voiceDropdownBtn) (voiceDropdownBtn as HTMLButtonElement).disabled = isActive;
  };

  const resetHighlight = () => getReadableElements().forEach(el => el.classList.remove('reading-highlight'));

  const highlightElement = (index: number) => {
    resetHighlight();
    const elements = getReadableElements();
    if (index >= 0 && index < elements.length) {
      elements[index].classList.add('reading-highlight');
      elements[index].scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  };

  const fetchAudio = async (text: string): Promise<HTMLAudioElement | null> => {
    try {
      const res = await fetch('/api/tts', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text, voice: selectedVoice }),
      });
      if (!res.ok) {
        const errJson = await res.json().catch(() => ({}));
        console.error('[TTS] API error:', errJson);
        return null;
      }
      const blob = await res.blob();
      return new Audio(URL.createObjectURL(blob));
    } catch (err) {
      console.error('[TTS] fetch error:', err);
      return null;
    }
  };

  const prefetchNext = async () => {
    const els = getReadableElements();
    if (currentElementIndex + 1 < els.length) {
      nextAudio = await fetchAudio((els[currentElementIndex + 1].textContent || '').trim());
    } else {
      nextAudio = null;
    }
  };

  const playCurrentChunk = async () => {
    const elements = getReadableElements();
    if (currentElementIndex >= elements.length) {
      resetHighlight();
      updateUIState('ready');
      currentElementIndex = 0;
      return;
    }

    const text = (elements[currentElementIndex].textContent || '').trim();
    highlightElement(currentElementIndex);

    if (!currentAudio) {
      updateUIState('generating');
      currentAudio = await fetchAudio(text);
      if (!currentAudio) { updateUIState('error'); return; }
    }

    if (isPaused) return;

    currentAudio.onended = () => {
      if (isPaused) return;
      currentElementIndex++;
      currentAudio = nextAudio;
      nextAudio = null;
      playCurrentChunk();
    };

    currentAudio.onerror = () => { console.error('[TTS] Playback error'); updateUIState('error'); };

    try {
      await currentAudio.play();
      isPlaying = true;
      updateUIState('playing');
      prefetchNext();
    } catch (err) {
      console.error('[TTS] play() failed:', err);
      updateUIState('error');
    }
  };

  playBtn?.addEventListener('click', () => {
    isPaused = false;
    if (currentAudio) {
      currentAudio.play().then(() => { isPlaying = true; updateUIState('playing'); }).catch(() => updateUIState('error'));
    } else {
      if (getReadableElements().length > 0) playCurrentChunk();
    }
  });

  pauseBtn?.addEventListener('click', () => {
    isPaused = true;
    currentAudio?.pause();
    isPlaying = false;
    updateUIState('paused');
  });

  stopBtn?.addEventListener('click', () => {
    isPaused = false;
    if (currentAudio) { currentAudio.pause(); currentAudio = null; }
    nextAudio = null;
    currentElementIndex = 0;
    resetHighlight();
    updateUIState('ready');
  });

  window.addEventListener('pagehide', () => currentAudio?.pause());
</script>

<style>
  /* ─── Player shell ─── */
  .premium-audio-player {
    background: linear-gradient(145deg, #1f1f22, #141416);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 1.25rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
    color: var(--white);
    margin: 2rem 0;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    transition: box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .premium-audio-player.is-playing {
    box-shadow: 0 10px 32px rgba(255, 107, 0, 0.18);
    border-color: rgba(255, 107, 0, 0.25);
  }

  /* ─── Top row ─── */
  .player-top-row {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  /* ─── Cover art ─── */
  .player-cover {
    width: 44px;
    height: 44px;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, var(--orange), #ff4500);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 4px 12px rgba(255, 107, 0, 0.35);
  }

  .disc-icon {
    color: white;
    animation: spin 8s linear infinite;
    animation-play-state: paused;
    display: flex;
  }

  .premium-audio-player.is-playing .disc-icon {
    animation-play-state: running;
  }

  @keyframes spin { 100% { transform: rotate(360deg); } }

  /* ─── Info area ─── */
  .player-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .player-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--gray-light);
    text-transform: uppercase;
  }

  /* ─── Waveform ─── */
  .waveform {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 18px;
  }

  .waveform .bar {
    display: block;
    width: 3px;
    background-color: rgba(255, 255, 255, 0.2);
    border-radius: 2px;
    height: 25%;
    transition: background-color 0.3s ease;
  }

  .waveform.active .bar {
    background-color: var(--orange);
    animation: bounce 1s infinite ease-in-out alternate;
  }

  .waveform.active .bar:nth-child(1)  { animation-delay: 0.0s; }
  .waveform.active .bar:nth-child(2)  { animation-delay: 0.15s; }
  .waveform.active .bar:nth-child(3)  { animation-delay: 0.3s; }
  .waveform.active .bar:nth-child(4)  { animation-delay: 0.07s; }
  .waveform.active .bar:nth-child(5)  { animation-delay: 0.45s; }
  .waveform.active .bar:nth-child(6)  { animation-delay: 0.22s; }
  .waveform.active .bar:nth-child(7)  { animation-delay: 0.55s; }
  .waveform.active .bar:nth-child(8)  { animation-delay: 0.12s; }
  .waveform.active .bar:nth-child(9)  { animation-delay: 0.6s; }
  .waveform.active .bar:nth-child(10) { animation-delay: 0.35s; }
  .waveform.active .bar:nth-child(11) { animation-delay: 0.08s; }
  .waveform.active .bar:nth-child(12) { animation-delay: 0.5s; }
  .waveform.active .bar:nth-child(13) { animation-delay: 0.25s; }
  .waveform.active .bar:nth-child(14) { animation-delay: 0.65s; }
  .waveform.active .bar:nth-child(15) { animation-delay: 0.18s; }
  .waveform.active .bar:nth-child(16) { animation-delay: 0.72s; }

  @keyframes bounce { 0% { height: 20%; } 100% { height: 100%; } }

  /* ─── Status badge ─── */
  .status-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gray-light);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 2rem;
    padding: 0.25rem 0.6rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .premium-audio-player.is-playing .status-badge {
    color: var(--orange);
    background: rgba(255, 107, 0, 0.1);
    border-color: rgba(255, 107, 0, 0.25);
  }

  /* ─── Bottom row ─── */
  .player-bottom-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding-top: 0.625rem;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  /* ─── Controls ─── */
  .player-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .play-pause-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--white);
    color: var(--ink);
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.15s ease, background-color 0.15s ease;
    flex-shrink: 0;
  }

  .play-pause-btn:hover { transform: scale(1.06); background: #f0f0f0; }
  .play-pause-btn.hidden { display: none; }

  .stop-btn {
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--gray-light);
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .stop-btn:hover { color: var(--orange); border-color: rgba(255, 107, 0, 0.3); }
  .stop-btn.hidden { display: none; }

  /* ─── Voice selector ─── */
  .voice-selector {
    position: relative;
  }

  .voice-pill {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: var(--white);
    padding: 0.375rem 0.75rem;
    border-radius: 2rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .voice-pill:hover:not(:disabled) {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .voice-pill:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  /* ─── Voice menu ─── */
  .voice-menu {
    position: absolute;
    bottom: calc(100% + 0.5rem);
    right: 0;
    background: rgba(22, 22, 25, 0.97);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    padding: 0.875rem;
    width: 200px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
    z-index: 30;
    transform-origin: bottom right;
    transition: opacity 0.2s ease, transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .voice-menu.hidden {
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px) scale(0.95);
  }

  .menu-title {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.35);
    margin-bottom: 0.625rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .voice-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.4rem;
  }

  .voice-chip {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.6);
    padding: 0.5rem 0.375rem;
    border-radius: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    cursor: pointer;
    transition: all 0.18s ease;
    text-align: center;
  }

  .voice-chip:hover {
    background: rgba(255, 255, 255, 0.1);
    color: var(--white);
  }

  .voice-chip.active {
    background: rgba(255, 107, 0, 0.12);
    border-color: rgba(255, 107, 0, 0.35);
    color: var(--orange);
    font-weight: 600;
  }

  /* ─── Reading highlight ─── */
  :global(.reading-highlight) {
    background-color: rgba(255, 107, 0, 0.12) !important;
    border-radius: 0.25rem;
    outline: 2px solid rgba(255, 107, 0, 0.2);
    outline-offset: 2px;
    transition: background-color 0.3s ease, outline 0.3s ease;
  }

  /* ─── Mobile tweaks ─── */
  @media (max-width: 480px) {
    .premium-audio-player {
      padding: 0.875rem 1rem;
      gap: 0.75rem;
    }

    /* Show fewer waveform bars on small screens */
    .waveform .bar:nth-child(n+13) { display: none; }

    .voice-menu {
      /* Ensure menu doesn't go off-screen on the right */
      right: 0;
      left: auto;
      width: 190px;
    }
  }
</style>
