---
// AudioPlayer Component
---
<div class="premium-audio-player" id="audioPlayerContainer">
  <div class="player-cover">
    <div class="disc-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <circle cx="12" cy="12" r="3"></circle>
      </svg>
    </div>
  </div>

  <div class="player-controls">
    <button id="playBtn" class="play-pause-btn" aria-label="Listen to article">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="6 3 20 12 6 21 6 3"></polygon></svg>
    </button>
    <button id="pauseBtn" class="play-pause-btn hidden" aria-label="Pause reading">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"></rect><rect x="14" y="4" width="4" height="16"></rect></svg>
    </button>
  </div>

  <div class="player-info">
    <span class="player-title">Listen to this article</span>
    <div class="waveform" id="waveform">
      <span class="bar"></span><span class="bar"></span><span class="bar"></span><span class="bar"></span>
      <span class="bar"></span><span class="bar"></span><span class="bar"></span><span class="bar"></span>
      <span class="bar"></span><span class="bar"></span><span class="bar"></span><span class="bar"></span>
      <span class="bar"></span><span class="bar"></span><span class="bar"></span><span class="bar"></span>
    </div>
  </div>

  <div class="player-actions">
    <div class="voice-dropdown-container" id="voiceDropdownContainer">
      <button id="voiceDropdownBtn" class="voice-settings-btn" aria-label="Change Voice">
        <svg class="voice-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" y1="19" x2="12" y2="22"></line></svg>
        <span id="selectedVoiceLabel">Asteria</span>
        <svg class="chevron-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
      </button>
      <div id="voiceDropdownMenu" class="modern-voice-menu hidden">
        <div class="menu-header">Select Voice</div>
        <div class="voice-grid">
          <button class="voice-chip active" data-voice="asteria">Asteria</button>
          <button class="voice-chip" data-voice="luna">Luna</button>
          <button class="voice-chip" data-voice="orion">Orion</button>
          <button class="voice-chip" data-voice="zeus">Zeus</button>
        </div>
      </div>
    </div>
    
    <span class="status-text" id="statusText">Ready</span>
    
    <button id="stopBtn" class="stop-btn hidden" aria-label="Stop reading" title="Stop">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect></svg>
    </button>
  </div>
</div>

<script>
  const playBtn = document.getElementById('playBtn');
  const pauseBtn = document.getElementById('pauseBtn');
  const stopBtn = document.getElementById('stopBtn');
  const statusText = document.getElementById('statusText');
  const waveform = document.getElementById('waveform');
  const playerContainer = document.getElementById('audioPlayerContainer');
  
  // Custom Dropdown logic
  const voiceDropdownBtn = document.getElementById('voiceDropdownBtn');
  const voiceDropdownMenu = document.getElementById('voiceDropdownMenu');
  const voiceOptions = document.querySelectorAll('.voice-chip');
  const selectedVoiceLabel = document.getElementById('selectedVoiceLabel');
  
  let selectedVoice = 'asteria';
  
  if (voiceDropdownBtn && voiceDropdownMenu) {
    voiceDropdownBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      voiceDropdownMenu.classList.toggle('hidden');
    });
    
    document.addEventListener('click', () => {
      voiceDropdownMenu.classList.add('hidden');
    });
    
    // Prevent closing when clicking inside the menu
    voiceDropdownMenu.addEventListener('click', (e) => {
      e.stopPropagation();
    });
    
    voiceOptions.forEach(option => {
      option.addEventListener('click', (e) => {
        const target = e.currentTarget;
        
        voiceOptions.forEach(opt => opt.classList.remove('active'));
        target.classList.add('active');
        selectedVoice = target.getAttribute('data-voice') || 'asteria';
        
        if (selectedVoiceLabel) {
          const text = target.textContent || '';
          selectedVoiceLabel.textContent = text;
        }
        
        voiceDropdownMenu.classList.add('hidden');
        
        if (currentAudio) {
          currentAudio.pause();
          currentAudio = null;
        }
        updateUIState('ready');
        resetHighlight();
        currentElementIndex = 0;
      });
    });
  }

  let readableElements = [];
  let currentElementIndex = 0;
  
  let currentAudio = null;
  let nextAudio = null;
  let isPlaying = false;
  let isGenerating = false;
  let isPaused = false;

  const getReadableElements = () => {
    if (readableElements.length === 0) {
      readableElements = Array.from(document.querySelectorAll('.prose p, .prose h2, .prose h3, .prose li'))
        .filter(el => el.textContent.trim().length > 0);
    }
    return readableElements;
  };

  const updateUIState = (state) => {
    if (!playBtn || !pauseBtn || !stopBtn || !statusText || !waveform || !playerContainer) return;

    if (state === 'generating') {
      playBtn.classList.add('hidden');
      pauseBtn.classList.add('hidden');
      stopBtn.classList.remove('hidden');
      statusText.textContent = 'Generating...';
      waveform.classList.add('active');
      playerContainer.classList.add('is-playing');
      if (voiceDropdownBtn) voiceDropdownBtn.disabled = true;
    } else if (state === 'playing') {
      playBtn.classList.add('hidden');
      pauseBtn.classList.remove('hidden');
      stopBtn.classList.remove('hidden');
      statusText.textContent = 'Playing';
      waveform.classList.add('active');
      playerContainer.classList.add('is-playing');
      if (voiceDropdownBtn) voiceDropdownBtn.disabled = true;
    } else if (state === 'paused') {
      playBtn.classList.remove('hidden');
      pauseBtn.classList.add('hidden');
      stopBtn.classList.remove('hidden');
      statusText.textContent = 'Paused';
      waveform.classList.remove('active');
      playerContainer.classList.remove('is-playing');
      if (voiceDropdownBtn) voiceDropdownBtn.disabled = false;
    } else if (state === 'error') {
      playBtn.classList.remove('hidden');
      pauseBtn.classList.add('hidden');
      stopBtn.classList.add('hidden');
      statusText.textContent = 'Error';
      waveform.classList.remove('active');
      playerContainer.classList.remove('is-playing');
      isGenerating = false;
      isPlaying = false;
      if (voiceDropdownBtn) voiceDropdownBtn.disabled = false;
    } else {
      playBtn.classList.remove('hidden');
      pauseBtn.classList.add('hidden');
      stopBtn.classList.add('hidden');
      statusText.textContent = 'Ready';
      waveform.classList.remove('active');
      playerContainer.classList.remove('is-playing');
      isGenerating = false;
      isPlaying = false;
      if (voiceDropdownBtn) voiceDropdownBtn.disabled = false;
    }
  };

  const resetHighlight = () => {
    getReadableElements().forEach(el => el.classList.remove('reading-highlight'));
  };

  const highlightElement = (index) => {
    resetHighlight();
    const elements = getReadableElements();
    if (index >= 0 && index < elements.length) {
      const el = elements[index];
      el.classList.add('reading-highlight');
      // Scroll into view smoothly
      el.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  };

  const fetchAudioForText = async (text) => {
    try {
      const response = await fetch('/api/tts', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text, voice: selectedVoice })
      });
      if (!response.ok) throw new Error('TTS fetch failed');
      const blob = await response.blob();
      const url = URL.createObjectURL(blob);
      const audio = new Audio(url);
      return audio;
    } catch (err) {
      console.error(err);
      return null;
    }
  };

  const prefetchNext = async () => {
    const elements = getReadableElements();
    if (currentElementIndex + 1 < elements.length) {
      const text = elements[currentElementIndex + 1].textContent.trim();
      nextAudio = await fetchAudioForText(text);
    } else {
      nextAudio = null;
    }
  };

  const playCurrentChunk = async () => {
    const elements = getReadableElements();
    if (currentElementIndex >= elements.length) {
      resetHighlight();
      updateUIState('ready');
      currentElementIndex = 0;
      return;
    }

    const text = elements[currentElementIndex].textContent.trim();
    highlightElement(currentElementIndex);
    
    if (!currentAudio) {
      updateUIState('generating');
      currentAudio = await fetchAudioForText(text);
      if (!currentAudio) {
        updateUIState('error');
        return;
      }
    }

    if (isPaused) {
      return; // If user paused during generation
    }

    currentAudio.onended = () => {
      if (isPaused) return;
      currentElementIndex++;
      currentAudio = nextAudio;
      nextAudio = null;
      playCurrentChunk();
    };

    currentAudio.onerror = () => {
      console.error("Audio playback error");
      updateUIState('error');
    };

    try {
      await currentAudio.play();
      isPlaying = true;
      updateUIState('playing');
      
      // Start prefetching next chunk
      prefetchNext();
    } catch (err) {
      console.error('Playback failed', err);
      updateUIState('error');
    }
  };

  if (playBtn && pauseBtn && stopBtn) {
    playBtn.addEventListener('click', () => {
      isPaused = false;
      if (currentAudio) {
        currentAudio.play().then(() => {
          isPlaying = true;
          updateUIState('playing');
        }).catch(() => updateUIState('error'));
      } else {
        const elements = getReadableElements();
        if (elements.length > 0) {
          playCurrentChunk();
        }
      }
    });

    pauseBtn.addEventListener('click', () => {
      isPaused = true;
      if (currentAudio) {
        currentAudio.pause();
      }
      isPlaying = false;
      updateUIState('paused');
    });

    stopBtn.addEventListener('click', () => {
      isPaused = false;
      if (currentAudio) {
        currentAudio.pause();
        currentAudio.currentTime = 0;
        currentAudio = null;
      }
      nextAudio = null;
      currentElementIndex = 0;
      resetHighlight();
      updateUIState('ready');
    });

    window.addEventListener('pagehide', () => {
      if (currentAudio) currentAudio.pause();
    });
  }
</script>

<style>
  .premium-audio-player {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: linear-gradient(145deg, #1f1f22, #141416);
    border-radius: 1rem;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    margin: 2rem 0;
    color: var(--white);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: box-shadow 0.3s ease;
  }

  .premium-audio-player.is-playing {
    box-shadow: 0 10px 30px rgba(255, 107, 0, 0.15);
    border-color: rgba(255, 107, 0, 0.2);
  }

  .player-cover {
    width: 48px;
    height: 48px;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, var(--orange), #ff4500);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 4px 10px rgba(255, 107, 0, 0.3);
  }

  .disc-icon {
    color: var(--white);
    animation: spin 8s linear infinite;
    animation-play-state: paused;
  }

  .premium-audio-player.is-playing .disc-icon {
    animation-play-state: running;
  }

  @keyframes spin {
    100% { transform: rotate(360deg); }
  }

  .player-controls {
    display: flex;
    align-items: center;
  }

  .play-pause-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--white);
    color: var(--ink);
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .play-pause-btn:hover {
    transform: scale(1.05);
    background-color: var(--off-white);
  }

  .play-pause-btn.hidden {
    display: none;
  }

  .player-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.375rem;
    overflow: hidden;
  }

  .player-title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--white);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .waveform {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 16px;
  }

  .waveform .bar {
    display: block;
    width: 3px;
    background-color: rgba(255, 255, 255, 0.3);
    border-radius: 2px;
    height: 20%;
    transition: background-color 0.3s ease;
  }

  .waveform.active .bar {
    background-color: var(--orange);
    animation: bounce 1s infinite ease-in-out alternate;
  }

  /* Randomize bounce delays for realistic waveform */
  .waveform.active .bar:nth-child(1) { animation-delay: 0.0s; }
  .waveform.active .bar:nth-child(2) { animation-delay: 0.2s; }
  .waveform.active .bar:nth-child(3) { animation-delay: 0.4s; }
  .waveform.active .bar:nth-child(4) { animation-delay: 0.1s; }
  .waveform.active .bar:nth-child(5) { animation-delay: 0.5s; }
  .waveform.active .bar:nth-child(6) { animation-delay: 0.3s; }
  .waveform.active .bar:nth-child(7) { animation-delay: 0.6s; }
  .waveform.active .bar:nth-child(8) { animation-delay: 0.2s; }
  .waveform.active .bar:nth-child(9) { animation-delay: 0.7s; }
  .waveform.active .bar:nth-child(10) { animation-delay: 0.4s; }
  .waveform.active .bar:nth-child(11) { animation-delay: 0.1s; }
  .waveform.active .bar:nth-child(12) { animation-delay: 0.5s; }
  .waveform.active .bar:nth-child(13) { animation-delay: 0.3s; }
  .waveform.active .bar:nth-child(14) { animation-delay: 0.6s; }
  .waveform.active .bar:nth-child(15) { animation-delay: 0.2s; }
  .waveform.active .bar:nth-child(16) { animation-delay: 0.8s; }

  @keyframes bounce {
    0% { height: 20%; }
    100% { height: 100%; }
  }

  .player-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-left: 0.75rem;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Custom Modern Dropdown Styles */
  .voice-dropdown-container {
    position: relative;
  }

  .voice-settings-btn {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--white);
    padding: 0.4rem 0.75rem;
    border-radius: 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .voice-settings-btn:hover:not(:disabled) {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
  }
  
  .voice-settings-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .voice-icon {
    color: var(--gray-light);
  }

  .chevron-icon {
    margin-left: 0.25rem;
    opacity: 0.7;
    transition: transform 0.2s ease;
  }

  .modern-voice-menu {
    position: absolute;
    bottom: calc(100% + 1rem);
    right: 0;
    background: rgba(26, 26, 28, 0.95);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    padding: 1rem;
    width: 220px;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
    z-index: 20;
    opacity: 1;
    transform: translateY(0);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    transform-origin: bottom right;
  }

  .modern-voice-menu.hidden {
    opacity: 0;
    pointer-events: none;
    transform: translateY(10px) scale(0.95);
  }

  .menu-header {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--gray);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .voice-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  .voice-chip {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    color: var(--gray-light);
    padding: 0.5rem;
    border-radius: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: center;
  }

  .voice-chip:hover {
    background: rgba(255, 255, 255, 0.08);
    color: var(--white);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .voice-chip.active {
    background: rgba(255, 107, 0, 0.1);
    color: var(--orange);
    border-color: rgba(255, 107, 0, 0.3);
    font-weight: 500;
    box-shadow: 0 0 10px rgba(255, 107, 0, 0.1);
  }

  .status-text {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--gray-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stop-btn {
    background: none;
    border: none;
    color: var(--gray-light);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem;
    transition: color 0.2s ease;
  }

  .stop-btn:hover {
    color: var(--orange);
  }

  .stop-btn.hidden {
    display: none;
  }

  @media (max-width: 640px) {
    .premium-audio-player {
      padding: 0.75rem;
      gap: 0.75rem;
    }
    
    .waveform .bar:nth-child(n+11) {
      display: none; /* Show fewer bars on mobile */
    }
    
    .status-text {
      display: none; /* Hide status text on small screens */
    }
    
    .player-actions {
      border-left: none;
      padding-left: 0;
      flex-direction: column;
      gap: 0.5rem;
      align-items: flex-end;
    }

    .modern-voice-menu {
      right: -2rem; /* Adjust position for mobile */
    }
  }

  :global(.reading-highlight) {
    background-color: rgba(255, 107, 0, 0.15) !important;
    border-radius: 0.25rem;
    box-shadow: 0 0 0 4px rgba(255, 107, 0, 0.15);
    transition: background-color 0.3s ease, box-shadow 0.3s ease;
  }
</style>
