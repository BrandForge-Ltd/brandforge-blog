---
export interface Props {
  textToRead: string;
}

const { textToRead } = Astro.props;
---

<div class="premium-audio-player" id="audioPlayerContainer">
  <div class="player-cover">
    <div class="disc-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <circle cx="12" cy="12" r="3"></circle>
      </svg>
    </div>
  </div>

  <div class="player-controls">
    <button id="playBtn" class="play-pause-btn" aria-label="Listen to article">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="6 3 20 12 6 21 6 3"></polygon></svg>
    </button>
    <button id="pauseBtn" class="play-pause-btn hidden" aria-label="Pause reading">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"></rect><rect x="14" y="4" width="4" height="16"></rect></svg>
    </button>
  </div>

  <div class="player-info">
    <span class="player-title">Listen to this article</span>
    <div class="waveform" id="waveform">
      <span class="bar"></span><span class="bar"></span><span class="bar"></span><span class="bar"></span>
      <span class="bar"></span><span class="bar"></span><span class="bar"></span><span class="bar"></span>
      <span class="bar"></span><span class="bar"></span><span class="bar"></span><span class="bar"></span>
      <span class="bar"></span><span class="bar"></span><span class="bar"></span><span class="bar"></span>
    </div>
  </div>

  <div class="player-actions">
    <select id="voiceSelector" class="voice-selector" aria-label="Select voice">
      <option value="@cf/deepgram/aura-asteria-en">Asteria (Female)</option>
      <option value="@cf/deepgram/aura-orion-en">Orion (Male)</option>
      <option value="@cf/deepgram/aura-luna-en">Luna (Female)</option>
      <option value="@cf/myshell-ai/melotts">MeloTTS</option>
    </select>
    <span class="status-text" id="statusText">Ready</span>
    <button id="stopBtn" class="stop-btn hidden" aria-label="Stop reading" title="Stop">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect></svg>
    </button>
  </div>

  {/* Hidden text container for the script to read */}
  <div id="textToRead" style="display: none;">{textToRead}</div>
</div>

<script>
  const playBtn = document.getElementById('playBtn');
  const pauseBtn = document.getElementById('pauseBtn');
  const stopBtn = document.getElementById('stopBtn');
  const textContainer = document.getElementById('textToRead');
  const statusText = document.getElementById('statusText');
  const waveform = document.getElementById('waveform');
  const playerContainer = document.getElementById('audioPlayerContainer');
  const voiceSelector = document.getElementById('voiceSelector') as HTMLSelectElement;
  
  let audioEl: HTMLAudioElement | null = null;
  let isGenerating = false;

  const updateUIState = (state: 'generating' | 'playing' | 'paused' | 'ready' | 'error') => {
    if (!playBtn || !pauseBtn || !stopBtn || !statusText || !waveform || !playerContainer) return;

    if (state === 'generating') {
      playBtn.classList.add('hidden');
      pauseBtn.classList.add('hidden');
      stopBtn.classList.remove('hidden');
      statusText.textContent = 'Generating...';
      waveform.classList.add('active');
      playerContainer.classList.add('is-playing');
      if (voiceSelector) voiceSelector.disabled = true;
    } else if (state === 'playing') {
      playBtn.classList.add('hidden');
      pauseBtn.classList.remove('hidden');
      stopBtn.classList.remove('hidden');
      statusText.textContent = 'Playing';
      waveform.classList.add('active');
      playerContainer.classList.add('is-playing');
      if (voiceSelector) voiceSelector.disabled = true;
    } else if (state === 'paused') {
      playBtn.classList.remove('hidden');
      pauseBtn.classList.add('hidden');
      stopBtn.classList.remove('hidden');
      statusText.textContent = 'Paused';
      waveform.classList.remove('active');
      playerContainer.classList.remove('is-playing');
      if (voiceSelector) voiceSelector.disabled = false;
    } else if (state === 'error') {
      playBtn.classList.remove('hidden');
      pauseBtn.classList.add('hidden');
      stopBtn.classList.add('hidden');
      statusText.textContent = 'Error';
      waveform.classList.remove('active');
      playerContainer.classList.remove('is-playing');
      isGenerating = false;
      if (voiceSelector) voiceSelector.disabled = false;
    } else {
      playBtn.classList.remove('hidden');
      pauseBtn.classList.add('hidden');
      stopBtn.classList.add('hidden');
      statusText.textContent = 'Ready';
      waveform.classList.remove('active');
      playerContainer.classList.remove('is-playing');
      isGenerating = false;
      if (voiceSelector) voiceSelector.disabled = false;
    }
  };

  const generateAndPlay = async () => {
    if (isGenerating || !textContainer) return;
    isGenerating = true;
    updateUIState('generating');
    
    try {
      const response = await fetch('/api/tts', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          text: textContainer.textContent,
          voice: voiceSelector ? voiceSelector.value : undefined
        })
      });
      
      if (!response.ok) {
        throw new Error('Failed to generate audio');
      }
      
      const blob = await response.blob();
      const url = URL.createObjectURL(blob);
      
      if (audioEl) {
        audioEl.pause();
        audioEl.src = '';
      }
      
      audioEl = new Audio(url);
      
      audioEl.onended = () => updateUIState('ready');
      audioEl.onerror = () => updateUIState('error');
      
      await audioEl.play();
      updateUIState('playing');
    } catch (err) {
      console.error('Audio playback error:', err);
      updateUIState('error');
    }
  };

  if (playBtn && pauseBtn && stopBtn) {
    playBtn.addEventListener('click', () => {
      if (audioEl) {
        if (audioEl.paused) {
          audioEl.play().then(() => updateUIState('playing')).catch(() => updateUIState('error'));
        }
      } else {
        generateAndPlay();
      }
    });

    pauseBtn.addEventListener('click', () => {
      if (audioEl) {
        audioEl.pause();
        updateUIState('paused');
      }
    });

    stopBtn.addEventListener('click', () => {
      if (audioEl) {
        audioEl.pause();
        audioEl.currentTime = 0;
      }
      updateUIState('ready');
    });
    
    if (voiceSelector) {
      voiceSelector.addEventListener('change', () => {
        if (audioEl) {
          audioEl.pause();
          audioEl = null;
        }
        updateUIState('ready');
      });
    }

    // Cleanup on page hide
    window.addEventListener('pagehide', () => {
      if (audioEl) {
        audioEl.pause();
      }
    });
  }
</script>

<style>
  .premium-audio-player {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: linear-gradient(145deg, #1f1f22, #141416);
    border-radius: 1rem;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    margin: 2rem 0;
    color: var(--white);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: box-shadow 0.3s ease;
  }

  .premium-audio-player.is-playing {
    box-shadow: 0 10px 30px rgba(255, 107, 0, 0.15);
    border-color: rgba(255, 107, 0, 0.2);
  }

  .player-cover {
    width: 48px;
    height: 48px;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, var(--orange), #ff4500);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 4px 10px rgba(255, 107, 0, 0.3);
  }

  .disc-icon {
    color: var(--white);
    animation: spin 8s linear infinite;
    animation-play-state: paused;
  }

  .premium-audio-player.is-playing .disc-icon {
    animation-play-state: running;
  }

  @keyframes spin {
    100% { transform: rotate(360deg); }
  }

  .player-controls {
    display: flex;
    align-items: center;
  }

  .play-pause-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--white);
    color: var(--ink);
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .play-pause-btn:hover {
    transform: scale(1.05);
    background-color: var(--off-white);
  }

  .play-pause-btn.hidden {
    display: none;
  }

  .player-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.375rem;
    overflow: hidden;
  }

  .player-title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--white);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .waveform {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 16px;
  }

  .waveform .bar {
    display: block;
    width: 3px;
    background-color: rgba(255, 255, 255, 0.3);
    border-radius: 2px;
    height: 20%;
    transition: background-color 0.3s ease;
  }

  .waveform.active .bar {
    background-color: var(--orange);
    animation: bounce 1s infinite ease-in-out alternate;
  }

  /* Randomize bounce delays for realistic waveform */
  .waveform.active .bar:nth-child(1) { animation-delay: 0.0s; }
  .waveform.active .bar:nth-child(2) { animation-delay: 0.2s; }
  .waveform.active .bar:nth-child(3) { animation-delay: 0.4s; }
  .waveform.active .bar:nth-child(4) { animation-delay: 0.1s; }
  .waveform.active .bar:nth-child(5) { animation-delay: 0.5s; }
  .waveform.active .bar:nth-child(6) { animation-delay: 0.3s; }
  .waveform.active .bar:nth-child(7) { animation-delay: 0.6s; }
  .waveform.active .bar:nth-child(8) { animation-delay: 0.2s; }
  .waveform.active .bar:nth-child(9) { animation-delay: 0.7s; }
  .waveform.active .bar:nth-child(10) { animation-delay: 0.4s; }
  .waveform.active .bar:nth-child(11) { animation-delay: 0.1s; }
  .waveform.active .bar:nth-child(12) { animation-delay: 0.5s; }
  .waveform.active .bar:nth-child(13) { animation-delay: 0.3s; }
  .waveform.active .bar:nth-child(14) { animation-delay: 0.6s; }
  .waveform.active .bar:nth-child(15) { animation-delay: 0.2s; }
  .waveform.active .bar:nth-child(16) { animation-delay: 0.8s; }

  @keyframes bounce {
    0% { height: 20%; }
    100% { height: 100%; }
  }

  .player-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-left: 0.5rem;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
  }

  .status-text {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--gray-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stop-btn {
    background: none;
    border: none;
    color: var(--gray-light);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem;
    transition: color 0.2s ease;
  }

  .stop-btn:hover {
    color: var(--orange);
  }

  .stop-btn.hidden {
    display: none;
  }

  .voice-selector {
    background-color: rgba(255, 255, 255, 0.1);
    color: var(--white);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 0.5rem;
    padding: 0.25rem 0.5rem;
    font-size: 0.75rem;
    font-family: var(--font-sans);
    cursor: pointer;
    outline: none;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .voice-selector:hover {
    background-color: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .voice-selector:focus {
    border-color: var(--orange);
  }

  .voice-selector option {
    background-color: var(--ink);
    color: var(--white);
  }

  @media (max-width: 640px) {
    .premium-audio-player {
      padding: 0.75rem;
      gap: 0.75rem;
    }
    
    .waveform .bar:nth-child(n+11) {
      display: none; /* Show fewer bars on mobile */
    }
    
    .status-text {
      display: none; /* Hide status text on small screens */
    }
    
    .player-actions {
      border-left: none;
      padding-left: 0;
      flex-direction: column;
      gap: 0.5rem;
      align-items: flex-end;
    }

    .voice-selector {
      max-width: 100px;
    }
  }
</style>
