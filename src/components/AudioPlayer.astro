---
// AudioPlayer Component — powered by Kokoro TTS (in-browser AI, no server required)
---
<div class="premium-audio-player" id="audioPlayerContainer">
  <div class="player-cover">
    <div class="disc-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <circle cx="12" cy="12" r="3"></circle>
      </svg>
    </div>
  </div>

  <div class="player-controls">
    <button id="playBtn" class="play-pause-btn" aria-label="Listen to article">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="6 3 20 12 6 21 6 3"></polygon></svg>
    </button>
    <button id="pauseBtn" class="play-pause-btn hidden" aria-label="Pause reading">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"></rect><rect x="14" y="4" width="4" height="16"></rect></svg>
    </button>
  </div>

  <div class="player-info">
    <span class="player-title">Listen to this article</span>
    <div class="waveform" id="waveform">
      <span class="bar"></span><span class="bar"></span><span class="bar"></span><span class="bar"></span>
      <span class="bar"></span><span class="bar"></span><span class="bar"></span><span class="bar"></span>
      <span class="bar"></span><span class="bar"></span><span class="bar"></span><span class="bar"></span>
      <span class="bar"></span><span class="bar"></span><span class="bar"></span><span class="bar"></span>
    </div>
  </div>

  <div class="player-actions">
    <div class="voice-dropdown-container" id="voiceDropdownContainer">
      <button id="voiceDropdownBtn" class="voice-dropdown-btn">
        <svg class="voice-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" y1="19" x2="12" y2="22"></line></svg>
        <span id="selectedVoiceLabel">Heart</span>
        <svg class="chevron-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
      </button>
      <div id="voiceDropdownMenu" class="voice-dropdown-menu hidden">
        <button class="voice-option active" data-voice="af_heart">Heart ♀</button>
        <button class="voice-option" data-voice="af_bella">Bella ♀</button>
        <button class="voice-option" data-voice="am_fenrir">Fenrir ♂</button>
        <button class="voice-option" data-voice="am_puck">Puck ♂</button>
      </div>
    </div>

    <span class="status-text" id="statusText">Ready</span>

    <button id="stopBtn" class="stop-btn hidden" aria-label="Stop reading" title="Stop">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect></svg>
    </button>
  </div>
</div>

<script type="module" is:inline>
  import { KokoroTTS } from 'https://cdn.jsdelivr.net/npm/kokoro-js@1.2.1/dist/kokoro.web.js';

  const MODEL_ID = 'onnx-community/Kokoro-82M-v1.0-ONNX';

  // ── DOM refs ──────────────────────────────────────────────────────────────
  const playBtn        = document.getElementById('playBtn') as HTMLButtonElement;
  const pauseBtn       = document.getElementById('pauseBtn') as HTMLButtonElement;
  const stopBtn        = document.getElementById('stopBtn') as HTMLButtonElement;
  const statusText     = document.getElementById('statusText') as HTMLSpanElement;
  const waveformEl     = document.getElementById('waveform') as HTMLDivElement;
  const playerContainer= document.getElementById('audioPlayerContainer') as HTMLDivElement;
  const voiceDropdownBtn = document.getElementById('voiceDropdownBtn') as HTMLButtonElement;
  const voiceDropdownMenu= document.getElementById('voiceDropdownMenu') as HTMLDivElement;
  const selectedVoiceLabel = document.getElementById('selectedVoiceLabel') as HTMLSpanElement;
  const voiceOptions   = document.querySelectorAll<HTMLButtonElement>('.voice-option');

  // ── State ─────────────────────────────────────────────────────────────────
  let tts: InstanceType<typeof KokoroTTS> | null = null;
  let isModelLoading = false;
  let selectedVoice  = 'af_heart';

  let readableElements: Element[] = [];
  let currentElementIndex = 0;
  let currentAudio: HTMLAudioElement | null = null;
  let nextAudio: HTMLAudioElement | null = null;
  let isPlaying  = false;
  let isPaused   = false;

  // ── UI state machine ─────────────────────────────────────────────────────
  const setState = (state: string) => {
    const active = state === 'generating' || state === 'playing';
    playBtn.classList.toggle('hidden',  state === 'playing' || state === 'generating');
    pauseBtn.classList.toggle('hidden', state !== 'playing');
    stopBtn.classList.toggle('hidden',  state === 'ready' || state === 'error');
    waveformEl.classList.toggle('active', active);
    playerContainer.classList.toggle('is-playing', active);
    voiceDropdownBtn.disabled = active || isModelLoading;

    const labels: Record<string, string> = {
      loading:    'Loading…',
      generating: 'Generating…',
      playing:    'Playing',
      paused:     'Paused',
      error:      'Error',
      ready:      'Ready',
    };
    statusText.textContent = labels[state] ?? 'Ready';
  };

  // ── Voice dropdown ────────────────────────────────────────────────────────
  voiceDropdownBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    voiceDropdownMenu.classList.toggle('hidden');
  });
  document.addEventListener('click', () => voiceDropdownMenu.classList.add('hidden'));

  voiceOptions.forEach(opt => {
    opt.addEventListener('click', (e) => {
      e.stopPropagation();
      voiceOptions.forEach(o => o.classList.remove('active'));
      opt.classList.add('active');
      selectedVoice = opt.getAttribute('data-voice') || 'af_heart';
      selectedVoiceLabel.textContent = (opt.textContent || '').replace(/ [♀♂]/, '');
      voiceDropdownMenu.classList.add('hidden');
      // Reset so next play uses new voice
      if (currentAudio) { currentAudio.pause(); currentAudio = null; }
      nextAudio = null;
      resetHighlight();
      currentElementIndex = 0;
      setState('ready');
    });
  });

  // ── Model loader ──────────────────────────────────────────────────────────
  const loadModel = async (): Promise<InstanceType<typeof KokoroTTS> | null> => {
    if (tts) return tts;
    if (isModelLoading) return null;
    isModelLoading = true;
    voiceDropdownBtn.disabled = true;
    setState('loading');

    try {
      tts = await KokoroTTS.from_pretrained(MODEL_ID, {
        dtype: 'q8',   // ~86MB quantised — best size/quality balance
        device: 'wasm',
        progress_callback: ({ status, progress }: { status: string; progress?: number; file?: string }) => {
          if (status === 'progress' && progress != null) {
            statusText.textContent = `Loading ${Math.round(progress)}%`;
          }
        },
      });
    } catch (err) {
      console.error('[Kokoro] Model load failed:', err);
      isModelLoading = false;
      setState('error');
      return null;
    }

    isModelLoading = false;
    return tts;
  };

  // ── Audio helpers ─────────────────────────────────────────────────────────
  const getReadableElements = (): Element[] => {
    if (readableElements.length === 0) {
      readableElements = Array.from(
        document.querySelectorAll('.prose p, .prose h2, .prose h3, .prose li')
      ).filter(el => (el.textContent || '').trim().length > 0);
    }
    return readableElements;
  };

  const resetHighlight = () =>
    getReadableElements().forEach(el => el.classList.remove('reading-highlight'));

  const highlightElement = (index: number) => {
    resetHighlight();
    const els = getReadableElements();
    if (index >= 0 && index < els.length) {
      els[index].classList.add('reading-highlight');
      els[index].scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  };

  const generateAudio = async (text: string): Promise<HTMLAudioElement | null> => {
    const model = await loadModel();
    if (!model) return null;
    try {
      setState('generating');
      const rawAudio = await model.generate(text, { voice: selectedVoice });
      const blob = rawAudio.toBlob();
      const url  = URL.createObjectURL(blob);
      return new Audio(url);
    } catch (err) {
      console.error('[Kokoro] Generation failed:', err);
      return null;
    }
  };

  const prefetchNext = async () => {
    const els = getReadableElements();
    if (currentElementIndex + 1 < els.length) {
      const text = (els[currentElementIndex + 1].textContent || '').trim();
      nextAudio = await generateAudio(text);
    } else {
      nextAudio = null;
    }
  };

  const playCurrentChunk = async () => {
    const els = getReadableElements();
    if (currentElementIndex >= els.length) {
      resetHighlight();
      setState('ready');
      currentElementIndex = 0;
      return;
    }

    const text = (els[currentElementIndex].textContent || '').trim();
    highlightElement(currentElementIndex);

    if (!currentAudio) {
      currentAudio = await generateAudio(text);
      if (!currentAudio) { setState('error'); return; }
    }

    if (isPaused) return;

    currentAudio.onended = () => {
      if (isPaused) return;
      currentElementIndex++;
      currentAudio = nextAudio;
      nextAudio = null;
      playCurrentChunk();
    };

    currentAudio.onerror = () => { console.error('[Kokoro] Playback error'); setState('error'); };

    try {
      await currentAudio.play();
      isPlaying = true;
      setState('playing');
      prefetchNext(); // start generating next chunk in background
    } catch (err) {
      console.error('[Kokoro] play() failed:', err);
      setState('error');
    }
  };

  // ── Button handlers ───────────────────────────────────────────────────────
  playBtn.addEventListener('click', () => {
    isPaused = false;
    if (currentAudio) {
      currentAudio.play()
        .then(() => { isPlaying = true; setState('playing'); })
        .catch(() => setState('error'));
    } else if (getReadableElements().length > 0) {
      playCurrentChunk();
    }
  });

  pauseBtn.addEventListener('click', () => {
    isPaused = true;
    currentAudio?.pause();
    isPlaying = false;
    setState('paused');
  });

  stopBtn.addEventListener('click', () => {
    isPaused = false;
    if (currentAudio) { currentAudio.pause(); currentAudio = null; }
    nextAudio = null;
    currentElementIndex = 0;
    resetHighlight();
    setState('ready');
  });

  window.addEventListener('pagehide', () => currentAudio?.pause());
</script>

<style>
  .premium-audio-player {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: linear-gradient(145deg, #1f1f22, #141416);
    border-radius: 1rem;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    margin: 2rem 0;
    color: var(--white);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: box-shadow 0.3s ease;
  }

  .premium-audio-player.is-playing {
    box-shadow: 0 10px 30px rgba(255, 107, 0, 0.15);
    border-color: rgba(255, 107, 0, 0.2);
  }

  .player-cover {
    width: 48px;
    height: 48px;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, var(--orange), #ff4500);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 4px 10px rgba(255, 107, 0, 0.3);
  }

  .disc-icon {
    color: var(--white);
    animation: spin 8s linear infinite;
    animation-play-state: paused;
  }

  .premium-audio-player.is-playing .disc-icon {
    animation-play-state: running;
  }

  @keyframes spin {
    100% { transform: rotate(360deg); }
  }

  .player-controls {
    display: flex;
    align-items: center;
  }

  .play-pause-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--white);
    color: var(--ink);
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .play-pause-btn:hover {
    transform: scale(1.05);
    background-color: var(--off-white);
  }

  .play-pause-btn.hidden {
    display: none;
  }

  .player-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.375rem;
    overflow: hidden;
    min-width: 0;
  }

  .player-title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--white);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .waveform {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 16px;
  }

  .waveform .bar {
    display: block;
    width: 3px;
    background-color: rgba(255, 255, 255, 0.3);
    border-radius: 2px;
    height: 20%;
    transition: background-color 0.3s ease;
  }

  .waveform.active .bar {
    background-color: var(--orange);
    animation: bounce 1s infinite ease-in-out alternate;
  }

  .waveform.active .bar:nth-child(1)  { animation-delay: 0.0s; }
  .waveform.active .bar:nth-child(2)  { animation-delay: 0.2s; }
  .waveform.active .bar:nth-child(3)  { animation-delay: 0.4s; }
  .waveform.active .bar:nth-child(4)  { animation-delay: 0.1s; }
  .waveform.active .bar:nth-child(5)  { animation-delay: 0.5s; }
  .waveform.active .bar:nth-child(6)  { animation-delay: 0.3s; }
  .waveform.active .bar:nth-child(7)  { animation-delay: 0.6s; }
  .waveform.active .bar:nth-child(8)  { animation-delay: 0.2s; }
  .waveform.active .bar:nth-child(9)  { animation-delay: 0.7s; }
  .waveform.active .bar:nth-child(10) { animation-delay: 0.4s; }
  .waveform.active .bar:nth-child(11) { animation-delay: 0.1s; }
  .waveform.active .bar:nth-child(12) { animation-delay: 0.5s; }
  .waveform.active .bar:nth-child(13) { animation-delay: 0.3s; }
  .waveform.active .bar:nth-child(14) { animation-delay: 0.6s; }
  .waveform.active .bar:nth-child(15) { animation-delay: 0.2s; }
  .waveform.active .bar:nth-child(16) { animation-delay: 0.8s; }

  @keyframes bounce {
    0%   { height: 20%; }
    100% { height: 100%; }
  }

  .player-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .voice-dropdown-container {
    position: relative;
  }

  .voice-dropdown-btn {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--white);
    padding: 0.4rem 0.75rem;
    border-radius: 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .voice-dropdown-btn:hover:not(:disabled) {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .voice-dropdown-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .voice-icon {
    color: var(--gray-light);
    flex-shrink: 0;
  }

  .chevron-icon {
    opacity: 0.7;
    flex-shrink: 0;
  }

  .voice-dropdown-menu {
    position: absolute;
    bottom: calc(100% + 0.5rem);
    right: 0;
    background: #1a1a1c;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.75rem;
    padding: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 160px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
    z-index: 20;
    opacity: 1;
    transform: translateY(0);
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    transform-origin: bottom right;
  }

  .voice-dropdown-menu.hidden {
    opacity: 0;
    pointer-events: none;
    transform: translateY(10px) scale(0.95);
  }

  .voice-option {
    background: transparent;
    border: none;
    color: var(--gray-light);
    padding: 0.5rem 0.75rem;
    text-align: left;
    border-radius: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .voice-option:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--white);
  }

  .voice-option.active {
    background: rgba(255, 107, 0, 0.15);
    color: var(--orange);
    font-weight: 500;
  }

  .status-text {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: var(--gray-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .stop-btn {
    background: none;
    border: none;
    color: var(--gray-light);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem;
    transition: color 0.2s ease;
    flex-shrink: 0;
  }

  .stop-btn:hover {
    color: var(--orange);
  }

  .stop-btn.hidden {
    display: none;
  }

  /* Mobile: wrap actions to a second row */
  @media (max-width: 600px) {
    .premium-audio-player {
      flex-wrap: wrap;
      padding: 0.875rem;
      gap: 0.75rem;
    }

    .player-cover {
      width: 40px;
      height: 40px;
    }

    .player-info {
      flex: 1;
    }

    /* Hide extra waveform bars */
    .waveform .bar:nth-child(n+9) {
      display: none;
    }

    /* Actions on their own full-width row */
    .player-actions {
      width: 100%;
      justify-content: space-between;
      padding-top: 0.625rem;
      border-top: 1px solid rgba(255, 255, 255, 0.07);
    }

    .voice-dropdown-menu {
      right: 0;
    }
  }

  :global(.reading-highlight) {
    background-color: rgba(255, 107, 0, 0.15) !important;
    border-radius: 0.25rem;
    box-shadow: 0 0 0 4px rgba(255, 107, 0, 0.15);
    transition: background-color 0.3s ease, box-shadow 0.3s ease;
  }
</style>
