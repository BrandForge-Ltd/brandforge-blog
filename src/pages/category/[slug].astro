---
import Layout from '../../layouts/Layout.astro';
import PostFeed from '../../components/PostFeed';
import Sidebar from '../../components/Sidebar.astro';
import { client } from '../../lib/sanity';
import { categoriesQuery, postsByCategoryQuery } from '../../lib/queries';

export async function getStaticPaths() {
  const categories = await client.fetch(categoriesQuery);
  
  return categories.map((category: any) => ({
    params: { slug: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const { slug } = Astro.params;

const posts = await client.fetch(postsByCategoryQuery, {
  categorySlug: slug,
  start: 0,
  end: 12
});
---

<Layout title={`${category.title} - BrandForge Blog`} description={`Latest posts in ${category.title}`}>
  <section class="category-hero bg-off-white">
    <div class="container text-center">
      <p class="hero-eyebrow">Category</p>
      <h1 class="text-display">{category.title}</h1>
    </div>
  </section>

  <section class="posts-section section-py">
    <div class="container">
      <div class="blog-layout">
        <main class="main-content">
          <PostFeed client:load initialPosts={posts} categorySlug={slug} />
        </main>
        
        <aside class="sidebar-wrapper">
          <Sidebar />
        </aside>
      </div>
    </div>
  </section>
</Layout>

<style>
  .category-hero {
    padding: var(--section-py) 0;
    border-bottom: 1px solid var(--border);
  }
  
  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 1rem;
  }
  
  .text-center {
    text-align: center;
  }

  .blog-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .blog-layout {
      grid-template-columns: 1fr 350px;
      gap: 4rem;
    }
  }

</style>
