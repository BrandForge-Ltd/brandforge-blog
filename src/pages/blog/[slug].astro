---
import Layout from '../../layouts/Layout.astro';
import { client, urlFor } from '../../lib/sanity';
import { postBySlugQuery, relatedPostsQuery } from '../../lib/queries';
import PortableTextWithTOC from '../../components/PortableTextWithTOC.tsx';
import AudioPlayer from '../../components/AudioPlayer.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import RelatedCarousel from '../../components/RelatedCarousel.astro';
import Sidebar from '../../components/Sidebar.astro';
import MobileTOC from '../../components/MobileTOC.astro';
import A11yControls from '../../components/A11yControls.astro';

export async function getStaticPaths() {
  const query = `*[_type == "post" && defined(slug.current)][]{ "slug": slug.current }`;
  const posts = await client.fetch(query);
  
  return posts.map((post: any) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = await client.fetch(postBySlugQuery, { slug });

if (!post) {
  return Astro.redirect('/404');
}

const authors = post.authors || (post.author ? [post.author] : []);

// Fetch related articles
let relatedPosts = [];
if (post.category && post.category._id) {
  relatedPosts = await client.fetch(relatedPostsQuery, {
    categoryId: post.category._id,
    postId: post._id
  });
}

const formattedDate = new Date(post.publishedAt).toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric'
});

// Helper to extract text from portable text
function extractText(blocks: any[]): string {
  if (!blocks) return '';
  return blocks
    .filter(val => val._type === 'block')
    .map(block => {
      return block.children.map((child: any) => child.text).join('');
    })
    .join('\n\n');
}

const plainTextBody = extractText(post.body);
const currentUrl = `https://brandforgeinc.com/blog/${slug}`;

// Extract headings for TOC
const tocHeadings = [];
if (post.body) {
  post.body.forEach((block: any) => {
    if (block._type === 'block' && (block.style === 'h2' || block.style === 'h3')) {
      const text = extractText([block]);
      const id = text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
      tocHeadings.push({
        text,
        id,
        level: block.style === 'h2' ? 2 : 3
      });
    }
  });
}
---

<Layout 
  title={post.title} 
  description={post.excerpt} 
  image={post.mainImage ? urlFor(post.mainImage).width(1200).height(630).url() : undefined}
>
  <div id="progress-container" style="position: sticky; top: 80px; width: 100%; height: 4px; background-color: transparent; z-index: 99; margin-top: -4px;">
    <div id="progress-bar" style="width: 0%; height: 100%; background-color: var(--orange); transition: width 0.1s ease-out;"></div>
  </div>

  <article class="blog-post">
    <header class="post-header container">
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back to all posts
      </a>
      
      <div class="meta">
        {post.category && (
          <a href={`/category/${post.category.slug}`} class="tag tag-neutral">{post.category.title}</a>
        )}
        <span class="date">{formattedDate}</span>
        <span style="color: var(--gray); font-size: var(--text-small);">•</span>
        <span style="color: var(--gray); font-size: var(--text-small); font-weight: 600;">{post.readingTime ? Math.max(1, post.readingTime) : 1} min read</span>
      </div>
      
      <h1 class="text-display post-title">{post.title}</h1>
      
      <div class="post-actions-mobile">
        {authors.length > 0 && (
          <div class="author-info">
            <div class="author-avatars" style="display: flex;">
              {authors.map((author: any, index: number) => (
                <div class="author-avatar" style={index > 0 ? "margin-left: -1rem; border: 2px solid var(--white);" : ""}>
                  {author.image ? (
                    <img src={urlFor(author.image).width(100).height(100).url()} alt={typeof author === 'string' ? author : author.name} style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;" />
                  ) : (
                    (typeof author === 'string' ? author : (author.name || 'A')).charAt(0)
                  )}
                </div>
              ))}
            </div>
            <div class="author-details">
              <span class="author-label">Written By</span>
              <span class="author-name">
                {authors.map((a: any) => typeof a === 'string' ? a : a.name).join(' & ')}
              </span>
            </div>
          </div>
        )}
        <div class="mobile-share-top">
          <ShareButtons url={currentUrl} title={post.title} />
        </div>
      </div>
    </header>

    {post.coverImage && (
      <div class="cover-image-container container">
        <img 
          src={urlFor(post.coverImage).width(2000).height(1125).url()} 
          alt={post.coverImage.alt || post.title} 
          class="cover-image"
        />
      </div>
    )}

    <div class="post-layout container">
      <!-- Left Sidebar (Share) -->
      <aside class="post-share-sidebar">
        <div class="sticky-share" style="display: flex; flex-direction: column; gap: 2rem; align-items: center;">
          <ShareButtons url={currentUrl} title={post.title} layout="vertical" />
          <A11yControls layout="vertical" />
        </div>
      </aside>

      <!-- Main Content -->
      <main class="post-main">
        <div class="summary-box">
          <div class="summary-header">
            <h3>Summary</h3>
          </div>
          <div class="summary-content" id="summaryContent">
            <p>{post.excerpt}</p>
          </div>
          <button id="toggleSummaryBtn" class="toggle-summary-btn">
            See more
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="chevron"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          
          <AudioPlayer textToRead={plainTextBody} />
        </div>

        <div class="prose">
          <PortableTextWithTOC value={post.body} currentUrl={currentUrl} />
        </div>

        <!-- Footer mobile share -->
        <div class="post-footer">
          <ShareButtons url={currentUrl} title={post.title} />
        </div>

        {authors.length > 0 && authors.some((a: any) => typeof a !== 'string') && (
          <div class="author-profiles-section">
            <h3 class="author-section-title">
              {authors.length > 1 ? 'About the Authors' : 'About the Author'}
            </h3>
            <div class="author-profiles-list">
              {authors.filter((a: any) => typeof a !== 'string').map((author: any) => (
                <div class="author-profile-card">
                  <div class="author-profile-image">
                    {author.image ? (
                      <img src={urlFor(author.image).width(150).height(150).url()} alt={author.name} />
                    ) : (
                      <div class="author-placeholder">
                        {(author.name || 'A').charAt(0)}
                      </div>
                    )}
                  </div>
                  <div class="author-profile-content">
                    <h4>{author.name}</h4>
                    {author.bio ? (
                      <div class="author-bio-text">
                        <PortableTextWithTOC value={author.bio} />
                      </div>
                    ) : (
                      <p class="author-default-bio">Contributing Author at BrandForge.</p>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </main>
      
      <!-- Right Sidebar (TOC, CTA, Categories) -->
      <aside class="post-right-sidebar">
        <Sidebar tocHeadings={tocHeadings} />
      </aside>
    </div>
  </article>

  <MobileTOC tocHeadings={tocHeadings} />

  {relatedPosts.length > 0 && (
    <section class="related-articles section-py bg-off-white">
      <div class="container">
        <h2 class="section-title">Related Articles</h2>
        <RelatedCarousel posts={relatedPosts} />
      </div>
    </section>
  )}

  <script>
    // Progress Bar
    const updateProgressBar = () => {
      const progressBar = document.getElementById('progress-bar');
      if (!progressBar) return;

      const windowScroll = document.documentElement.scrollTop || document.body.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = (windowScroll / height) * 100;
      progressBar.style.width = scrolled + '%';
    };

    window.addEventListener('scroll', updateProgressBar);
    updateProgressBar();

    // Summary Toggle
    const summaryContent = document.getElementById('summaryContent');
    const toggleBtn = document.getElementById('toggleSummaryBtn');
    
    if (summaryContent && toggleBtn) {
      // Only show toggle button if content is actually clamped
      // A simple way is to check scrollHeight vs clientHeight, but with webkit-line-clamp it can be tricky.
      // We will just always show it, or check if text is long enough.
      const textLength = summaryContent.textContent?.length || 0;
      if (textLength < 150) {
        toggleBtn.style.display = 'none';
        summaryContent.style.webkitLineClamp = 'unset';
      }

      toggleBtn.addEventListener('click', () => {
        const isExpanded = summaryContent.classList.contains('expanded');
        if (isExpanded) {
          summaryContent.classList.remove('expanded');
          toggleBtn.innerHTML = `See more <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="chevron"><polyline points="6 9 12 15 18 9"></polyline></svg>`;
        } else {
          summaryContent.classList.add('expanded');
          toggleBtn.innerHTML = `See less <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="chevron" style="transform: rotate(180deg);"><polyline points="6 9 12 15 18 9"></polyline></svg>`;
        }
      });
    }

    // Highlight to Share
    const prose = document.querySelector('.prose');
    let shareTooltip = document.getElementById('highlight-share-tooltip');
    
    if (prose && !shareTooltip) {
      shareTooltip = document.createElement('div');
      shareTooltip.id = 'highlight-share-tooltip';
      shareTooltip.className = 'highlight-share-tooltip';
      shareTooltip.innerHTML = `
        <button id="hs-twitter" aria-label="Share on X (Twitter)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </button>
        <button id="hs-linkedin" aria-label="Share on LinkedIn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
        </button>
      `;
      document.body.appendChild(shareTooltip);

      const twBtn = document.getElementById('hs-twitter');
      const liBtn = document.getElementById('hs-linkedin');
      
      let selectedText = '';

      document.addEventListener('selectionchange', () => {
        const selection = window.getSelection();
        if (!selection || selection.rangeCount === 0 || selection.isCollapsed) {
          shareTooltip.classList.remove('show');
          return;
        }

        if (!prose.contains(selection.anchorNode)) {
          shareTooltip.classList.remove('show');
          return;
        }

        selectedText = selection.toString().trim();
        if (selectedText.length < 5) {
          shareTooltip.classList.remove('show');
          return;
        }

        const range = selection.getRangeAt(0);
        const rect = range.getBoundingClientRect();
        
        shareTooltip.style.top = `${rect.top + window.scrollY - 40}px`;
        shareTooltip.style.left = `${rect.left + (rect.width / 2)}px`;
        shareTooltip.classList.add('show');
      });

      const currentUrl = encodeURIComponent(window.location.href);

      twBtn?.addEventListener('click', () => {
        const text = encodeURIComponent(`"${selectedText}"`);
        window.open(`https://twitter.com/intent/tweet?url=${currentUrl}&text=${text}`, '_blank');
      });

      liBtn?.addEventListener('click', () => {
        window.open(`https://www.linkedin.com/sharing/share-offsite/?url=${currentUrl}`, '_blank');
      });
    }
  </script>
</Layout>

<style>
  html {
    scroll-behavior: smooth;
  }

  .blog-post {
    background-color: var(--white);
    padding-bottom: var(--section-py);
  }

  .post-header {
    padding-top: calc(var(--section-py) * 0.8);
    padding-bottom: 2rem;
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--zinc-800);
    font-size: var(--text-label);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 2rem;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--orange);
  }

  .meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .date {
    color: var(--gray);
    font-size: var(--text-small);
    font-weight: 600;
  }

  .post-title {
    margin-bottom: 2rem;
  }

  .post-actions-mobile {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    gap: 1.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  @media (min-width: 768px) {
    .post-actions-mobile {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .author-info {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .author-avatar {
    width: 3rem;
    height: 3rem;
    background-color: var(--zinc-800);
    color: var(--white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.25rem;
  }

  .author-details {
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  .author-label {
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray);
  }

  .author-name {
    font-weight: 700;
    color: var(--ink);
  }

  .mobile-share-top {
    display: block;
  }

  @media (min-width: 1024px) {
    .mobile-share-top {
      display: none;
    }
  }

  .cover-image-container {
    margin-bottom: 4rem;
  }

  .cover-image {
    width: 100%;
    border-radius: 1.5rem;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  }

  /* 3-Column Layout */
  .post-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (min-width: 1024px) {
    .post-layout {
      grid-template-columns: 60px 1fr 320px;
      gap: 3rem;
    }
  }

  @media (min-width: 1280px) {
    .post-layout {
      grid-template-columns: 60px 1fr 350px;
      gap: 4rem;
    }
  }

  .post-main {
    min-width: 0;
  }

  .post-share-sidebar {
    display: none;
  }

  @media (min-width: 1024px) {
    .post-share-sidebar {
      display: block;
    }
  }

  .sticky-share {
    position: sticky;
    top: 120px;
    display: flex;
    justify-content: center;
  }

  .post-right-sidebar {
    display: none;
  }

  @media (min-width: 1024px) {
    .post-right-sidebar {
      display: block;
    }
  }

  /* Summary Box */
  .summary-box {
    background-color: var(--off-white);
    padding: 2.5rem;
    border-radius: 1.5rem;
    margin-bottom: 3rem;
    border: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .summary-header h3 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--ink);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .summary-header h3::before {
    content: '';
    display: block;
    width: 4px;
    height: 1.5rem;
    background-color: var(--orange);
    border-radius: 2px;
  }

  .summary-content {
    font-size: 1.125rem;
    color: var(--charcoal);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .summary-content.expanded {
    -webkit-line-clamp: unset;
  }

  .toggle-summary-btn {
    background: none;
    border: none;
    color: var(--orange);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.875rem;
    cursor: pointer;
    padding: 0;
    margin-top: 1rem;
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    transition: color 0.2s ease;
  }

  .toggle-summary-btn:hover {
    color: var(--ink);
  }

  /* Basic Prose Styles */
  .prose {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--charcoal);
  }

  .prose :global(h2) {
    font-family: var(--font-serif);
    font-size: 2rem;
    margin-top: 3.5rem;
    margin-bottom: 1.5rem;
    color: var(--ink);
  }

  .prose :global(h3) {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--ink);
  }

  .prose :global(p) {
    margin-bottom: 1.5rem;
  }

  .prose :global(ul), .prose :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(a) {
    color: var(--orange);
    text-decoration: underline;
    text-underline-offset: 4px;
    font-weight: 500;
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--orange);
    padding-left: 1.5rem;
    margin: 2.5rem 0;
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-style: italic;
    color: var(--ink);
    background-color: var(--off-white);
    padding: 1.5rem 1.5rem 1.5rem 2rem;
    border-radius: 0 1rem 1rem 0;
  }
  
  .prose :global(img) {
    border-radius: 1rem;
    margin: 3rem 0;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  /* Highlight Share Tooltip */
  :global(.highlight-share-tooltip) {
    position: absolute;
    transform: translateX(-50%) translateY(10px);
    background-color: var(--ink);
    border-radius: 8px;
    padding: 0.5rem;
    display: flex;
    gap: 0.5rem;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 1000;
  }

  :global(.highlight-share-tooltip::after) {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 50%;
    transform: translateX(-50%);
    border-width: 6px 6px 0;
    border-style: solid;
    border-color: var(--ink) transparent transparent transparent;
  }

  :global(.highlight-share-tooltip.show) {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  :global(.highlight-share-tooltip button) {
    background: none;
    border: none;
    color: var(--white);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    transition: color 0.2s ease;
  }

  :global(.highlight-share-tooltip button:hover) {
    color: var(--orange);
  }

  /* Mobile share footer */
  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: center;
  }

  @media (min-width: 1024px) {
    .post-footer {
      display: none;
    }
  }

  /* Authors Section */
  .author-profiles-section {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 2px solid var(--border);
  }

  .author-section-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--ink);
    margin-bottom: 2rem;
  }

  .author-profiles-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .author-profile-card {
    display: flex;
    gap: 1.5rem;
    background-color: var(--off-white);
    padding: 2rem;
    border-radius: 1rem;
    align-items: flex-start;
    flex-wrap: wrap;
    border: 1px solid var(--border);
  }

  .author-profile-image {
    flex-shrink: 0;
  }

  .author-profile-image img {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
  }

  .author-placeholder {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background-color: var(--zinc-800);
    color: var(--white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
  }

  .author-profile-content {
    flex: 1;
    min-width: 200px;
  }

  .author-profile-content h4 {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 0.5rem;
    margin-top: 0;
  }

  .author-bio-text {
    color: var(--charcoal);
    font-size: 1rem;
    line-height: 1.6;
  }

  .author-default-bio {
    color: var(--gray);
    font-size: 0.875rem;
  }

  /* Related Articles */
  .related-articles {
    border-top: 1px solid var(--border);
  }

  .section-title {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    margin-bottom: 3rem;
    color: var(--ink);
    text-align: center;
  }
</style>
